{
  "name": "welyjs",
  "version": "0.0.4",
  "type": "module",
  "description": "Lightweight Web Component framework powered by a single defineComponent() factory",
  "main": "./dist/wely.umd.js",
  "module": "./dist/wely.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/wely.es.js",
      "require": "./dist/wely.umd.js"
    }
  },
  "bin": {
    "wely": "./bin/wely.mjs"
  },
  "files": [
    "dist",
    "bin",
    "vite.library.config.ts",
    "vite.dev.config.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:page": "node bin/wely.mjs page",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "wely": "node bin/wely.mjs",
    "build:bundle": "WELY_BUILD_MODE=bundle vite build --emptyOutDir false",
    "build:chunks": "WELY_BUILD_MODE=chunks vite build --emptyOutDir false",
    "prepublishOnly": "npm run build",
    "test:e2e": "vitest run e2e",
    "test:browser": "npm run build && npm run build:bundle && playwright test"
  },
  "browserslist": [
    "Chrome >= 73",
    "Firefox >= 101",
    "Safari >= 16.4",
    "Edge >= 79"
  ],
  "wely": { "componentsDir": "src/components" },
  "sideEffects": ["./src/components/**", "./src/bundle.ts", "./dist/wely.bundle.es.js", "./dist/wely.bundle.umd.js"],
  "license": "MIT",
  "repository": "https://github.com/litepacks/welyjs",
  "homepage": "https://litepacks.github.io/welyjs/",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "lit": "^3.3.2",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jsdom": "^28.1.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
